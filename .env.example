# ============================================
# DeepResearchWeb 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填写实际值

# ========== 数据库配置 ==========
MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_USER=drw
MYSQL_PASSWORD=your_secure_password
DATABASE_URL=mysql+pymysql://drw:your_secure_password@mysql:3306/deepresearch

# 数据库连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=3600

# ========== Neo4j 配置 ==========
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_MAX_CONNECTIONS=50

# ========== Redis 配置 ==========
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=100
CACHE_TTL=1800

# ========== RabbitMQ 配置 ==========
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=your_rabbitmq_password

# ========== Milvus 配置 ==========
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_MAX_CONNECTIONS=30

# ========== Qdrant 配置 ==========
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ========== JWT 配置 ==========
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== LLM 配置 ==========
OPENAI_API_KEY=sk-your-openai-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_MAX_CONCURRENT=20

# ========== 搜索配置 ==========
TAVILY_API_KEY=tvly-your-tavily-api-key
SERPAPI_KEY=your-serpapi-key

# ========== ARQ 任务队列配置 ==========
ARQ_MAX_JOBS=50
ARQ_JOB_TIMEOUT=600
ARQ_MAX_TRIES=3
ARQ_HEALTH_CHECK_INTERVAL=30

# ========== MemOS 配置 ==========

# 偏好记忆集合配置（Milvus 向量存储）
# 显式偏好记忆（用户明确表达的偏好）
MEMOS_EXPLICIT_PREF_COLLECTION=explicit_preference
# 隐式偏好记忆（从行为中推断的偏好）
MEMOS_IMPLICIT_PREF_COLLECTION=implicit_preference
# 树形记忆集合（Qdrant 向量存储 + Neo4j 图存储）
MEMOS_TREE_COLLECTION=tree_memory

# Embedding 模型配置（用于偏好记忆和树形记忆的向量化）
# 支持的模型: BAAI/bge-large-zh-v1.5, BAAI/bge-base-zh-v1.5, openai/text-embedding-ada-002 等
MEMOS_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# Embedding API URL（如使用 OpenAI: https://api.openai.com/v1/embeddings）
MEMOS_EMBEDDING_URL=
# Embedding API Key
MEMOS_EMBEDDING_API_KEY=

# Reranker 模型配置（用于搜索结果重排序）
# 支持的模型: BAAI/bge-reranker-base, BAAI/bge-reranker-large 等
MEMOS_RERANKER_MODEL=BAAI/bge-reranker-base
# Reranker API URL
MEMOS_RERANKER_URL=
# Reranker API Key
MEMOS_RERANKER_API_KEY=

# ========== CORS 配置 ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ========== 应用配置 ==========
DEBUG=false
ENV=production
APP_NAME=DeepResearchWeb
APP_VERSION=0.1.0
